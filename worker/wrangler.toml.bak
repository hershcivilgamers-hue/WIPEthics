# =============================================================================
# wrangler.toml — CAIRO.AIC API Worker
#
# Two values must be filled in before deploying (see RUNBOOK.md):
#   • database_id   — printed when you run `wrangler d1 create cairo-aic`
#   • ALLOWED_ORIGIN — the web address the app is served from (for CORS)
# =============================================================================

name = "cairo-aic-api"
main = "src/index.js"
compatibility_date = "2026-06-01"

# The D1 database binding. `binding = "DB"` is what the Worker code references
# as env.DB — do not change it. Fill in database_id after creating the database.
[[d1_databases]]
binding = "DB"
database_name = "cairo-aic"
database_id = "PASTE_DATABASE_ID_HERE"

[vars]
# The origin the app is served from, e.g. "https://yourname.github.io" or your
# Google Site address. Used for CORS so only your site may call the API.
# Leave as "*" only while testing.
ALLOWED_ORIGIN = "*"
# How long a login stays valid, in hours.
SESSION_TTL_HOURS = "12"
